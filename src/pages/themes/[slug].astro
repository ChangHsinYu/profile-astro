---
import Layout from "../../layouts/Layout.astro";
import { getEntries, getEntry } from "../../utils/content.js";
import { getThemeWorks } from "../../utils/themes.js";

export function getStaticPaths() {
  return getEntries("themes").map((entry) => ({ params: { slug: entry.slug } }));
}

const entry = getEntry("themes", Astro.params.slug);
if (!entry) return Astro.redirect("/404");

const data = entry.data;
const titleEn = data.title_en || data.title?.en || data.title || data.title_zh;
const titleZh = data.title_zh || data.title?.zh || data.title || data.title_en;
const introductionEh = data.introduction_en || data.introduction?.en || data.introduction || data.introduction_zh;
const introductionZh = data.introduction_zh || data.introduction?.zh || data.introduction || data.introduction_en;
const works = getThemeWorks(entry);
---

<Layout title={titleEn || "Theme"}>
  <div class="work_main">
  <div class="work_layout">
    <div class="work_side_list">
      <!-- <ul class="theme_card_links">
        <li>
          <a href="javascript:history.back()">Back</a>
          <div style="height: 3rem;"></div>
        </li>
      </ul> -->
      <div class="ttl" data-lang="en">{titleEn}</div> 
      <div class="ttl" data-lang="zh">{titleZh}</div>
      </br>
      <ul class="theme_card_links">
        <li data-lang="en">{introductionEh}<br /></li>
        <li data-lang="zh">{introductionZh}<br /></li>
      </ul>
      <p style="margin-top:5rem;display: inline-block;font-size:0.8rem; border-bottom: 1px solid #000;">Related works</p>
      {works.length > 0 && (
          <ul class="theme_card_links">
            {works.map((work) => (
              <li style="text-align: left; text-align-last: left; overflow-wrap: break-word;">
                <a href={work.href}>{work.title}</a>
              </li>
            ))}
          </ul>
      )}
    </div>
    <div class="work_content">
      {entry.featuredImage && <img class="img" src={entry.featuredImage} alt={titleEn || "theme"} />}
      <div class="ttlbox">
        <div class="ttl" data-lang="en">{titleEn}</div>
        <div class="ttl" data-lang="zh">{titleZh}</div>
        <div class="inf" data-lang="en">{introductionEh}<br /></div>
        <div class="inf" data-lang="zh">{introductionZh}<br /></div>
      </div>

      <div data-lang="en" set:html={entry.languageHtml.en} />
      <div data-lang="zh" set:html={entry.languageHtml.zh} />
      
    </div>  
  </div>
  </div>
</Layout>