---
import Layout from "../../layouts/Layout.astro";
import { getEntries, getEntry } from "../../utils/content.js";

export function getStaticPaths() {
  return getEntries("collaborations").map((entry) => ({ params: { slug: entry.slug } }));
}

const entry = getEntry("collaborations", Astro.params.slug);
if (!entry) return Astro.redirect("/404");
const data = entry.data;
const media = data.media || [];
---

<Layout title={data.title || "Collaborations"}>
  <div class="work_main">
  <div class="work_layout">
    <div class="work_side_list">
      <div class="ttl">{data.title}</div><br />
      <ul class="theme_card_links">
        <li><br />{data.category}</li><br />
        <li>Year : <br />{data.date}</li><br />
        <li>Event : <br />{data.event}</li><br />
      </ul>
    </div>

    <div class="work_content">
    {entry.featuredImage && <img class="img" src={entry.featuredImage} alt={data.title || "artwork"} />}
    <div class="ttlbox">
      <div class="ttl">{data.title}</div>
      <div class="inf">Position : {data.category}<br />{data.material}<br /> Year : {data.date}</div>
    </div>

    <div data-lang="en" set:html={entry.languageHtml.en} />
    <div data-lang="zh" set:html={entry.languageHtml.zh} />
    <div class="imggrid">
    {media.map((item) => (
      item.type === "image" ? (
        <div class="box">
          <img class="subimg" src={item.src} alt={item.alt || data.title || "artwork image"} />
          {item.credit && <div class="photocredit">(photo by : {item.credit})</div>}
        </div>
      ) : null
    ))}
  </div>
  {media.map((item) => (
      item.type === "video" ? (
        <div>
          <iframe title={item.title || data.title || "video"} src={item.src} frameborder="0" allow={item.allow} allowfullscreen></iframe>
        </div>
      ) : null
    ))}
    </div>
  </div>
  </div>
</Layout>