---
import { Image } from "astro:assets";
import { getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";

const entry = await getEntry("cv", "main");
const cv = entry?.data.cv || {};
const portrait = entry?.data.portrait;

const languages = [
  ["en", cv.en],
  ["zh", cv.zh]
].filter(([, content]) => Boolean(content));
---

<Layout title="chang hsin-yu 張欣語 cv">
  <div class="work_main">
    {portrait && (
      <div class="cv_img">
        <Image
          class="img"
          src={portrait}
          alt="Chang Hsin-Yu portrait"
          widths={[400, 800, 1200]}
          format="webp"
        />
      </div>
    )}

    <div class="cv_content">
      {languages.map(([language, content]) => (
        <div class="cv_content_language" data-lang={language}>
          <div style="font-size:1.4rem">{content.name}<br /></div>
          <br />

          {content.bio && <div>{content.bio}</div>}
          <br />
          <br />

          {content.sections?.map((section) => (
            <div>
              <span class="cv_title">{section.title}</span><br /><br />

              {section.items?.map((item) => (
                <div class="cv_item">
                  <div class="cv_year">{item.year}</div>
                  <div class="cv_inf" style="border-bottom: 1px solid #000;">
                    {item.text}
                  </div>
                  <br />
                </div>
              ))}

              <br />
              <br />
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>
</Layout>