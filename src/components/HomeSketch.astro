<div id="sketch-root" style="text-align:center"></div>

<script>
  import p5 from "p5";

  const root = document.getElementById("sketch-root");
  if (root) {
    new p5((p) => {
      let ballNum = 10;
      let ballSize = 15;
      let ballTh = [];
      let ballPh = [];
      let thSpeed = [];
      let phSpeed = [];
      let rad = 0;

      p.setup = () => {
        const wide = window.innerWidth > 800;
        p.createCanvas(wide ? window.innerWidth * 2 / 3 : window.innerWidth, wide ? window.innerHeight * 2 / 3 : window.innerHeight * 0.7, p.WEBGL);
        ballSize = wide ? p.canvas.width / 20 : p.canvas.height / 15;
        p.noStroke();
        for (let i = 0; i < ballNum; i += 1) {
          ballTh[i] = p.random(0, 2 * p.PI);
          ballPh[i] = p.random(0, 2 * p.PI);
          thSpeed[i] = p.random(0, 0.05);
          phSpeed[i] = p.random(0, 0.05);
        }
      };

      p.draw = () => {
        p.background(255);
        p.rotateX(rad);
        p.rotateY(rad);
        rad += 0.001;
        for (let i = 0; i < ballNum; i += 1) {
          const x = ballSize * p.cos(ballTh[i]) * p.cos(ballPh[i]);
          const y = ballSize * p.sin(ballTh[i]) * p.cos(ballPh[i]);
          const z = ballSize * p.sin(ballPh[i]);
          p.push();
          p.translate(x, y, z);
          p.fill(0);
          p.sphere(ballSize, 36, 36);
          p.pop();
          ballTh[i] += thSpeed[i];
          ballPh[i] += phSpeed[i];
        }
      };

      p.windowResized = () => {
        const wide = window.innerWidth > 800;
        p.resizeCanvas(wide ? window.innerWidth * 2 / 3 : window.innerWidth, wide ? window.innerHeight * 2 / 3 : window.innerHeight * 0.7);
        ballSize = wide ? p.canvas.width / 20 : p.canvas.height / 15;
      };
    }, root);
  }
</script>
