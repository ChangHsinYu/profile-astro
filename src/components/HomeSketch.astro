<div id="sketch-root" style="width:100%;text-align:center;overflow:hidden;"></div>

<script>
  const root = document.getElementById("sketch-root");

  if (root) {
    const { default: p5 } = await import("p5");

    new p5((p) => {
      let ballNum = 10;
      let ballSize = 15;
      let ballTh = [];
      let ballPh = [];
      let thSpeed = [];
      let phSpeed = [];
      let rad = 0;

      function getCanvasSize() {
        const wide = window.innerWidth > 800;
        const width = root.clientWidth || window.innerWidth;
        const height = wide ? window.innerHeight * 2 / 3 : window.innerHeight * 0.55;

        return { width, height, wide };
      }

      function updateSize() {
        const { width, height, wide } = getCanvasSize();

        if (p.canvas) {
          p.resizeCanvas(width, height);
        }

        ballSize = wide ? width / 15 : Math.min(width, height) / 9;
      }

      p.setup = () => {
        const { width, height } = getCanvasSize();

        p.createCanvas(width, height, p.WEBGL);
        updateSize();
        p.noStroke();

        for (let i = 0; i < ballNum; i += 1) {
          ballTh[i] = p.random(0, 2 * p.PI);
          ballPh[i] = p.random(0, 2 * p.PI);
          thSpeed[i] = p.random(0, 0.05);
          phSpeed[i] = p.random(0, 0.05);
        }
      };

      p.draw = () => {
        p.background(255);
        p.rotateX(rad);
        p.rotateY(rad);
        rad += 0.001;

        for (let i = 0; i < ballNum; i += 1) {
          const x = ballSize * p.cos(ballTh[i]) * p.cos(ballPh[i]);
          const y = ballSize * p.sin(ballTh[i]) * p.cos(ballPh[i]);
          const z = ballSize * p.sin(ballPh[i]);

          p.push();
          p.translate(x, y, z);
          p.fill(0);
          p.sphere(ballSize, 36, 36);
          p.pop();

          ballTh[i] += thSpeed[i];
          ballPh[i] += phSpeed[i];
        }
      };

      p.windowResized = () => {
        updateSize();
      };
    }, root);
  }
</script>