---
const { entry } = Astro.props;
---

<div class="project">
  <a href={entry.href}>
    {entry.featuredImage ? (
      <img src={entry.featuredImage} style="width:100%;height:100%;object-fit:cover;aspect-ratio:8/5" alt={entry.data.title || "project"} />
    ) : (
      <div class="project-placeholder">Missing image</div>
    )}
  </a>
</div>

<style>
  .project-placeholder {
    align-items: center;
    aspect-ratio: 8 / 5;
    background: #f2f2f2;
    color: #888;
    display: flex;
    font-size: 0.75rem;
    justify-content: center;
    width: 100%;
  }
</style>
