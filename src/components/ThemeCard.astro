---
import "../styles/theme-card.css";
import { getThemeWorks } from "../utils/themes.js";

const { entry } = Astro.props;
const data = entry.data;
const works = getThemeWorks(entry);

const titleEn = data.title_en || data.title?.en || data.title || data.title_zh;
const titleZh = data.title_zh || data.title?.zh || data.title || data.title_en;
const introductionEn = data.introduction?.en || data.introduction_en || "";
const introductionZh = data.introduction?.zh || data.introduction_zh || introductionEn;
---
<div class="theme_card" id={`theme-${entry.slug}`}>
  <a href={entry.href}>
    {entry.featuredImage && (
      <img class="theme_card_img" src={entry.featuredImage} alt={titleEn || "theme"} />
    )}

    <h2 class="theme_card_title" data-lang="en">{titleEn}</h2>
    <h2 class="theme_card_title" data-lang="zh">{titleZh}</h2>

    {introductionEn && <p class="theme_card_introduction" data-lang="en">{introductionEn}</p>}
    {introductionZh && <p class="theme_card_introduction" data-lang="zh">{introductionZh}</p>}
  </a>
  {works.length > 0 && (
    <ul class="theme_card_works">
      {works.map((work) => <li><a href={work.href}>{work.title}</a></li>)}
    </ul>
  )}
</div>