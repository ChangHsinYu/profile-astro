---
import { Image } from "astro:assets";
import { marked } from "marked";

const { blocks = [], lang, title = "" } = Astro.props;

const defaultAllow =
  "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share";

function markdownToHtml(content = "") {
  return marked.parse(content);
}
---

<div class="content_blocks" data-lang={lang}>
  {blocks.map((block) => (
    block.type === "text" ? (
      <div class="dscrptn" set:html={markdownToHtml(block.content)} />
    ) : block.type === "image" ? (
      <div class="box">
        <Image
          class="subimg"
          src={block.src}
          alt={block.alt || title || ""}
          widths={[600, 1000, 1600, 2200]}
          format="webp"
          loading="lazy"
          decoding="async"
        />
        {block.credit && <div class="photocredit">(photo by : {block.credit})</div>}
      </div>
    ) : block.type === "video" ? (
      <iframe
        title={block.title || title || "video"}
        src={block.src}
        frameborder="0"
        allow={block.allow || defaultAllow}
        allowfullscreen
      ></iframe>
    ) : null
  ))}

  <div class="box"></div>
</div>