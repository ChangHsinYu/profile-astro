---
import { Image } from "astro:assets";

const { entry, category = "artworks" } = Astro.props;
const data = entry.data;

const href = `/${category}/${entry.slug}/`;
const featuredImage = data.featuredImage;
---

<a class="artwork_card" href={href}>
  {featuredImage ? (
    <Image
      src={featuredImage}
      class="work_img"
      alt={data.title || "artwork"}
      widths={[400, 700, 1000]}
      format="webp"
      loading="lazy"
      decoding="async"
    />
    ) : (
    <div class="missing-image">Missing image</div>
  )}

  <div class="work_inf_mobile">
    <li><span style="font-weight:300">{data.title}</span></li>
    <li>{data.category}</li>
    <li>{data.date}</li>
  </div>

  <ul class="work_inf">
    <li><span style="font-weight:300">{data.title}</span></li>
    <li>{data.category}</li>
    <li>{data.date}</li>
  </ul>
</a>

<style>
  .artwork_card {
    color: inherit;
    display: block;
    text-decoration: none;
    width: 100%;
  }

  .work_img {
    width: 100%;
    overflow: hidden;
  }

  .artwork_card_img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .missing-image {
    align-items: center;
    background: #f2f2f2;
    color: #888;
    display: flex;
    font-size: 0.75rem;
    height: 100%;
    justify-content: center;
    width: 100%;
  }
</style>